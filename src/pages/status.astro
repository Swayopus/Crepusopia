---
// @page /status — 随记（微博客）：按时间倒序展示 src/content/status/*.md 内容
// Data sources: getCollection("status")
import Layout from "@layouts/Layout.astro";
import { getCollection } from "astro:content";
import { formatDate } from "@utils/index";

const entries = await getCollection("status");

// 按日期倒序排列（最新在前），并预先渲染每条随记的 Markdown 内容
const sorted = await Promise.all(
  entries
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
    .map(async (entry) => {
      const { Content } = await entry.render();
      return { ...entry, Content };
    }),
);
---

<Layout title="Status" slug="status">
  <div class="pt-2 lg:pt-0">
    {/* ===== 页面标题与随记计数 ===== */}
    <h1 class="text-2xl font-semibold text-[var(--color-text)] mb-6">
      随记
      <span
        class="text-base text-[var(--color-text-muted)] font-normal ml-2"
        style="font-family: var(--font-nav)">{sorted.length} 条随记</span
      >
    </h1>

    {/* ===== 时间线布局：垂直连接线 + 圆点标记 ===== */}
    <div class="relative ml-2">
      <div class="absolute left-[5px] top-2 bottom-0 w-px bg-[var(--color-border)]"></div>
      <div class="space-y-6">
        {
          sorted.map((entry) => {
            const dateStr = formatDate(entry.data.date);
            return (
              <div class="relative pl-8">
                {/* 时间线圆点 */}
                <div class="absolute left-0 top-1.5 w-[11px] h-[11px] rounded-full border-2 border-[var(--color-border)] bg-[var(--color-bg)] ring-2 ring-[var(--color-bg)]" />
                <div class="flex items-baseline gap-4">
                  <span class="text-sm text-[var(--color-text-muted)]/60 w-24 flex-shrink-0">
                    {dateStr}
                  </span>
                  {/* 随记正文：若有外链则整体可点击 */}
                  <div class="text-base text-[var(--color-text)] leading-relaxed status-body">
                    {entry.data.link ? (
                      <a
                        href={entry.data.link}
                        class="hover:text-[var(--color-primary)] transition-colors"
                      >
                        <entry.Content />
                      </a>
                    ) : (
                      <entry.Content />
                    )}
                  </div>
                </div>
              </div>
            );
          })
        }
      </div>
    </div>
  </div>
</Layout>

{/* ===== 随记内容样式（全局） ===== */}
<style is:global>
  /* 随记 Markdown 渲染 —— 紧凑排版 */
  .status-body h1 {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0.75rem 0 0.25rem;
  }
  .status-body h2 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0.5rem 0 0.25rem;
  }
  .status-body p {
    margin: 0;
    display: inline;
  }
  .status-body ul {
    list-style: disc;
    padding-left: 1.5rem;
    margin: 0.25rem 0;
  }
  .status-body ol {
    list-style: decimal;
    padding-left: 1.5rem;
    margin: 0.25rem 0;
  }
  .status-body blockquote {
    border-left: 3px solid var(--color-primary);
    padding-left: 0.75rem;
    margin: 0.5rem 0;
    color: var(--color-text-muted);
  }
</style>
