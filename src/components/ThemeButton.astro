---
// @component ThemeButton — 亮色/暗色主题切换按钮，带太阳/月亮图标，支持 View Transition 动画
---

{/* 主题切换按钮 — 太阳图标（亮色模式可见），月亮图标（暗色模式可见） */}
<button id="theme-toggle-btn" class="icon-btn" aria-label="Toggle theme">
  {/* 月亮图标 — 仅暗色模式显示 */}
  <svg class="hidden dark:block w-[18px] h-[18px]" fill="currentColor" viewBox="0 0 24 24"
    ><path
      d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"
    ></path></svg
  >
  {/* 太阳图标 — 仅亮色模式显示 */}
  <svg class="block dark:hidden w-[18px] h-[18px]" fill="currentColor" viewBox="0 0 24 24"
    ><path
      d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z"
    ></path></svg
  >
</button>

{/*
  主题切换按钮点击逻辑。
  applyTheme() 和 astro:after-swap 已在 Head.astro 中统一注册，
  此处仅处理按钮点击事件。
*/}
<script is:inline>
  document.addEventListener("click", function (e) {
    if (e.target && e.target.closest("#theme-toggle-btn")) {
      var isDark = !document.documentElement.classList.contains("dark");
      applyTheme(isDark);
    }
  });
</script>
