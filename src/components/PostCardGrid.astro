---
// @component PostCardGrid — 网格布局文章卡片（带封面图）
import type { Post } from "@utils/content";
import { formatDate } from "@utils/date";
import { getPostUrl } from "@utils/slug";
import { getReadingStats } from "@utils/reading-time";

interface Props {
  post: Post;
}

const { post } = Astro.props;
const { data, body: rawBody } = post;
const stats = rawBody ? getReadingStats(rawBody) : { words: 0, minutes: 0 };
const desc = data.description || "";
---

<a
  href={getPostUrl(post)}
  class="group block rounded-xl border border-[var(--color-card-border)] bg-[var(--color-card-bg)] overflow-hidden hover:border-[var(--color-primary)]/30 hover:shadow-md transition-all duration-300"
>
  {data.image && (
    <div class="aspect-video overflow-hidden">
      <img
        src={data.image}
        alt={data.title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    </div>
  )}
  <div class="p-5">
    <div class="flex items-center gap-2 text-sm text-[var(--color-text-muted)] mb-2">
      {formatDate(data.published)}
      {data.updated && data.updated.getTime() !== data.published.getTime() && (
        <>
          <span>·</span>
          <span>Updated {formatDate(data.updated)}</span>
        </>
      )}
      {data.category && (
        <>
          <span>·</span>
          <span class="text-[var(--color-primary)]">{data.category}</span>
        </>
      )}
      <span>·</span>
      <span>{stats.words.toLocaleString()} 字 · {stats.minutes} 分钟</span>
    </div>

    <h2 class="text-lg font-semibold text-[var(--color-text)] mb-2 group-hover:text-[var(--color-primary)] transition-colors line-clamp-2">
      {data.title}
    </h2>

    {desc && <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{desc}</p>}

    {data.tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mt-3">
        {data.tags.slice(0, 3).map((t) => (
          <span class="px-2 py-0.5 text-xs leading-snug rounded-md bg-[var(--color-bg-alt)] text-[var(--color-text-muted)]">
            {t}
          </span>
        ))}
      </div>
    )}
  </div>
</a>
